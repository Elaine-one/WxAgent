# ============================================================
# LLM 厂商配置
# ============================================================

# 方式一：OpenAI 兼容接口（DeepSeek、Qwen、智谱、OpenAI 等）
LLM_PROVIDER=openai
LLM_API_KEY=sk-你的APIKey
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 方式二：Anthropic 原生接口（Claude 官方 API）
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-api03-你的APIKey
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-sonnet-4-6

# ============================================================
# 工作区配置
# ============================================================

# Agent 工作区目录（所有写操作、生成文件、venv 都在此目录下）
# 不设置则默认为项目目录下的 workspace/
# WORKSPACE_DIR=D:\Code\wechat-claude\workspace

# ============================================================
# Agent 后端
# ============================================================

# legacy: 简单循环（默认）
# langgraph: 状态图（支持中断/确认/自愈）
# AGENT_BACKEND=langgraph
