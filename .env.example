# ============================================================
# LLM 厂商配置
# ============================================================

# 方式一：OpenAI 兼容接口（DeepSeek、Qwen、智谱、OpenAI 等）
LLM_PROVIDER=openai
LLM_API_KEY=sk-你的APIKey
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 备用 LLM 配置（主模型不可用时自动切换）
# LLM_FALLBACK_API_KEY=sk-你的备用APIKey
# LLM_FALLBACK_BASE_URL=https://api.openai.com/v1
# LLM_FALLBACK_MODEL=gpt-4o

# 视觉模型配置（图片理解，不设置则默认使用 LLM_API_KEY）
# VISION_API_KEY=sk-你的视觉APIKey
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_MODEL=gpt-4o

# 方式二：Anthropic 原生接口（Claude 官方 API）
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-api03-你的APIKey
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-sonnet-4-6

# ============================================================
# 工作区配置
# ============================================================

# Agent 工作区目录（所有写操作、生成文件、venv 都在此目录下）
# 不设置则默认为项目目录下的 workspace/
# WORKSPACE_DIR=D:\Code\wechat-claude\workspace

# ============================================================
# Agent 后端
# ============================================================

# legacy: 简单循环（默认）
# langgraph: 状态图（支持中断/确认/自愈）
# AGENT_BACKEND=langgraph

# ============================================================
# 行为限制（覆盖 config.yaml 中的 limits 配置）
# ============================================================

# MAX_TOOL_ROUNDS=10
# MAX_HISTORY=20
# PYTHON_TIMEOUT=60
# PYTHON_MAX_OUTPUT=50000
# SHELL_TIMEOUT=30

# ============================================================
# 高级配置（覆盖 config.yaml 中的 advanced 配置）
# ============================================================

# ADV_MAX_TOKENS=2048
# ADV_MAX_CHARS=480
# ADV_DEBOUNCE_DELAY=3.0
# ADV_MAX_SESSIONS=100
# ADV_SESSION_TTL_SECONDS=86400
# ADV_MESSAGES_WINDOW=50
# ADV_SHORT_TERM_MAX_MESSAGES=50
# ADV_LONG_TERM_MAX_MESSAGES=20
# ADV_EMBEDDING_MODEL=BAAI/bge-small-zh
# ADV_LLM_FALLBACK_TIMEOUT=30.0
# ADV_ARIA2_RPC_URL=http://localhost:6800/jsonrpc
# ADV_GITHUB_MIRRORS 不支持环境变量覆盖（列表类型）
# ADV_WHISPER_MODEL=base
# ADV_WHISPER_DEVICE=cpu
# ADV_WHISPER_COMPUTE_TYPE=int8
# ADV_WHISPER_CLOUD_MODEL=whisper-1
